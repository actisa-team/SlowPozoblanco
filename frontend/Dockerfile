# Build Stage
FROM node:20-alpine as build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

# Inyectar las variables de Railway en el proceso de compilacion
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
ARG VITE_API_VERSION
ENV VITE_API_VERSION=$VITE_API_VERSION
ARG VITE_ENVIRONMENT
ENV VITE_ENVIRONMENT=$VITE_ENVIRONMENT
ARG VITE_JWT_STORAGE_KEY
ENV VITE_JWT_STORAGE_KEY=$VITE_JWT_STORAGE_KEY
ARG VITE_MAP_TILE_PROVIDER
ENV VITE_MAP_TILE_PROVIDER=$VITE_MAP_TILE_PROVIDER
ARG VITE_MAP_ATTRIBUTION
ENV VITE_MAP_ATTRIBUTION=$VITE_MAP_ATTRIBUTION
ARG VITE_REFRESH_TOKEN_KEY
ENV VITE_REFRESH_TOKEN_KEY=$VITE_REFRESH_TOKEN_KEY

RUN npx vite build

# Production Stage
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
